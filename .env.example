# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (producción: https://salesintelligence.verymuch.ai)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Anthropic (agentes Prospect Intel, Brief, etc.)
ANTHROPIC_API_KEY=sk-ant-api03-...
# Opcional: ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (si aún usas rutas legacy)
OPENAI_API_KEY=sk-your-openai-key

# GHL Integration (webhooks bidireccionales via N8N)
# Clave secreta que N8N usa en el header X-Api-Key al llamar /api/webhook/ghl-stage-change
SALES_AI_WEBHOOK_KEY=your-32-char-secret-key
# Si GHL_WEBHOOK_ENABLED=false, el endpoint rechaza con 503 (futuro use)
GHL_WEBHOOK_ENABLED=true

# Paperclip API (dashboard proxy routes — /api/paperclip/*)
# URL de la API de Paperclip (default: http://127.0.0.1:3100 para local)
PAPERCLIP_API_URL=http://127.0.0.1:3100
# Company ID de Verymuch.ai en Paperclip
PAPERCLIP_COMPANY_ID=c8ab35a2-ee55-49d9-a87c-a45b2b22a60c
# API Key con permisos de lectura (board user token o agent JWT)
PAPERCLIP_DASHBOARD_API_KEY=your-paperclip-api-key
# Q2 2026 goal ID (default incluido en código, sobreescribible aquí)
PAPERCLIP_Q2_GOAL_ID=75eff205-131b-4ed2-afb3-9c2a5fab5653
