  "tags": ["ghl", "sales-team-ai", "phase-1"],
  "_readme": {
    "title": "Workflow 1: GHL Stage Change → sales-team-ai",
    "description": "Receives GHL opportunity.stageChanged webhook, validates secret, maps stage to workflow, and forwards to sales-team-ai coordinator.",
    "credentials_required": [
      "headerAuth (GHL_WEBHOOK_SECRET) — for incoming webhook validation",
      "salesAiWebhookKey — API key for sales-intelligence.verymuch.ai (SALES_AI_WEBHOOK_KEY)",
      "goHighLevelApi — GHL Location API Key (GHL_LOCATION_API_KEY)",
      "Slack OAuth — for #tech-alerts notifications"
    ],
    "setup_steps": [
      "1. Import this JSON into n8n.verymuch.ai",
      "2. Create Header Auth credential named 'GHL Webhook Secret' with value = GHL_WEBHOOK_SECRET",
      "3. Create HTTP Header Auth credential named 'Sales AI Webhook Key' for outbound calls",
      "4. Create GoHighLevel API credential with GHL_LOCATION_API_KEY",
      "5. Connect Slack credential",
      "6. Activate the workflow — webhook URL: https://n8n.verymuch.ai/webhook/ghl-inbound",
      "7. Configure GHL Workflow to POST to that URL with header X-Webhook-Secret"
    ]
  }
}
