  "pinData": {},
  "versionId": "1.0.0",
  "triggerCount": 1,
  "tags": ["ghl", "sales-team-ai", "phase-1"],
  "_readme": {
    "title": "Workflow 2: sales-team-ai Output → GHL",
    "description": "Receives output from sales-team-ai agents, formats note, adds note + tags to GHL contact, updates opportunity custom fields, and conditionally updates stage.",
    "credentials_required": [
      "internalWebhookToken — X-Internal-Token for inbound validation (INTERNAL_WEBHOOK_TOKEN)",
      "goHighLevelApi — GHL Location API Key (GHL_LOCATION_API_KEY)",
      "Slack OAuth — for #tech-alerts notifications"
    ],
    "setup_steps": [
      "1. Import this JSON into n8n.verymuch.ai",
      "2. Create HTTP Header Auth credential 'Internal Webhook Token' with value = INTERNAL_WEBHOOK_TOKEN",
      "3. Create GoHighLevel API credential with GHL_LOCATION_API_KEY",
      "4. Connect Slack credential",
      "5. Activate the workflow — webhook URL: https://n8n.verymuch.ai/webhook/sales-ai-output",
      "6. In sales-team-ai: POST to that URL with X-Internal-Token header after agent completes"
    ]
  }
}
